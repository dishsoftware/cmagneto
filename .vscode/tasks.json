{
    "version": "2.0.0", // Schema version of VS Code’s Task Runner configuration.
    "inputs": [
        {
            "id": "buildType",
            "type": "pickString",
            "description": "Select build type for tasks.json",
            "options": [
                "Debug",
                "Release",
                "RelWithDebInfo",
                "MinSizeRel"
            ],
            "default": "Debug",
        }
    ],
    "tasks": [
        {
            "label": "Linux GCC. Build",
            "detail": "Build with GCC on Linux",
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "type": "shell",
            "command": "python",
            "args": [
                "${workspaceFolder}/build.py",
                "--toolset", "UnixMakefiles_GCC",
                "--build_types", "${input:buildType}",
                "--run_type", "Build"
            ],
            "problemMatcher": []
        },
        {
            "label": "Linux GCC. Run",
            "detail": "Run binaries, compiled with GCC on Linux",
            "group": {
                "kind": "none",
                "isDefault": false
            },
            "type": "shell",
            "command": "python",
            "args": [
                "${workspaceFolder}/build/UnixMakefiles_GCC/${input:buildType}/bin/run.py"
            ],
            "problemMatcher": []
        },

        {
            "label": "Windows MinGW. Build",
            "detail": "Build with MinGW on Windows",
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "type": "shell",
            "command": "python",
            "args": [
                "${workspaceFolder}\\build.py",
                "--toolset", "MinGWMakefiles_MinGW",
                "--build_types", "${input:buildType}",
                "--run_type", "Build"
            ],
            "problemMatcher": []
        },
        {
            "label": "Windows MinGW. Run",
            "detail": "Run binaries, compiled with MinGW on Windows",
            "group": {
                "kind": "none",
                "isDefault": false
            },
            "type": "shell",
            "command": "python",
            "args": [
                "${workspaceFolder}\\build\\MinGW\\${input:buildType}\\bin\\run.py"
            ],
            "problemMatcher": []
        }
    ]
}