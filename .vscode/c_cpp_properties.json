{
    "version": 4,
    "configurations": [
        {
            "name": "Linux_GCC",
            "compileCommands": "${workspaceFolder}/SeedProject/build/compile_commands.json",
            "compilerPath": "/usr/bin/g++",
            "intelliSenseMode": "linux-gcc-x64",
            "cStandard": "c17",
            "cppStandard": "gnu++17"
        },

        {
            "name": "Windows_MinGW",
            "compileCommands": "${workspaceFolder}/SeedProject/build/compile_commands.json",
            "compilerPath": "${MSYS2_HOME}/ucrt64/bin/c++.exe",
            "intelliSenseMode": "windows-gcc-x64",
            "cStandard": "c17",
            "cppStandard": "gnu++17"
        },

        {
            "name": "Windows_NinjaMC_MSVC",
            "compileCommands": "${workspaceFolder}/SeedProject/build/compile_commands.json",
            "compilerPath": "${VC2022ToolsInstallDir}/bin/Hostx64/x64/cl.exe",
            "intelliSenseMode": "windows-msvc-x64",
            "cStandard": "c17",
            "cppStandard": "c++17"
        },

        {
            "name": "Windows_VS2022_MSVC",
            "includePath": [
                "${workspaceFolder}/SeedProject/**",
                "${QT6_MSVC2022_DIR}/include/**",
                "${BOOST_MSVC2022_DIR}/../"
            ],
            "defines": [],
            "compilerPath": "${VC2022ToolsInstallDir}/bin/Hostx64/x64/cl.exe",
            "intelliSenseMode": "windows-msvc-x64",
            "cStandard": "c17",
            "cppStandard": "c++17"
        }
    ]
}
