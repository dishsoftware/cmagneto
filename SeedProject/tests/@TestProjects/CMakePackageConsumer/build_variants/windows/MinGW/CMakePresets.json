{
  "version": 10,
  "include": [
    "../../CMakePresets.common.json"
  ],
  "configurePresets": [
    {
      "name": "MinGW__base",
      "hidden": true,
      "inherits": "windows-host",
      "generator": "MinGW Makefiles",
      "binaryDir": "${sourceDir}/build/MinGW/$env{BuildType}",
      "environment": {
        "PATH": "$env{MSYS2_HOME}/ucrt64/bin${pathListSep}$penv{PATH}"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "$env{BuildType}",
        "CMAKE_CXX_COMPILER": "$env{MSYS2_HOME}/ucrt64/bin/g++.exe",
        "CMAKE_PREFIX_PATH": "$env{MSYS2_HOME}/ucrt64"
      }
    },
    {
      "name": "MinGW__Debug",
      "inherits": "MinGW__base",
      "environment": {
        "BuildType": "Debug"
      }
    },
    {
      "name": "MinGW__Release",
      "inherits": "MinGW__base",
      "environment": {
        "BuildType": "Release"
      }
    },
    {
      "name": "MinGW__RelWithDebInfo",
      "inherits": "MinGW__base",
      "environment": {
        "BuildType": "RelWithDebInfo"
      }
    },
    {
      "name": "MinGW__MinSizeRel",
      "inherits": "MinGW__base",
      "environment": {
        "BuildType": "MinSizeRel"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "MinGW__Debug",
      "configurePreset": "MinGW__Debug"
    },
    {
      "name": "MinGW__Release",
      "configurePreset": "MinGW__Release"
    },
    {
      "name": "MinGW__RelWithDebInfo",
      "configurePreset": "MinGW__RelWithDebInfo"
    },
    {
      "name": "MinGW__MinSizeRel",
      "configurePreset": "MinGW__MinSizeRel"
    }
  ]
}
