{
    "id": "qt6-base-msvc2022",
    "name": "Qt 6 Base for MSVC 2022",
    "notes": "Uses the local Qt installation selected by QT6_MSVC2022_DIR and its sibling source tree for legal texts.",
    "files": [
        {
            "kind": "license",
            "source": "$env{QT6_MSVC2022_DIR}/../Src/qtbase/LICENSES/LGPL-3.0-only.txt",
            "install": "licenses/3rd-party/qt6-base/LGPL-3.0-only.txt"
        },
        {
            "kind": "notice",
            "source": "$env{QT6_MSVC2022_DIR}/../Src/qtbase/LICENSES/Qt-GPL-exception-1.0.txt",
            "install": "licenses/3rd-party/qt6-base/Qt-GPL-exception-1.0.txt"
        }
    ]
}
