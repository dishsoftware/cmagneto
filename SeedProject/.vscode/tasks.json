{
    "version": "2.0.0", // Schema version of VS Code’s Task Runner configuration.
    "inputs": [
        {
            "id": "buildType",
            "type": "pickString",
            "description": "Select build type for tasks.json",
            "options": [
                "Debug",
                "Release",
                "RelWithDebInfo",
                "MinSizeRel"
            ],
            "default": "Debug",
        }
    ],
    "tasks": [
        {
            "label": "Linux GCC. Compile",
            "detail": "Compile with GCC on Linux",
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "type": "shell",
            "command": "python",
            "args": [
                "${workspaceFolder}/build.py",
                "--build_variant", "Makefiles_GCC",
                "--build_type", "${input:buildType}",
                "--build_stage", "Compile"
            ],
            "problemMatcher": []
        },

        {
            "label": "Windows MinGW. Compile",
            "detail": "Compile with MinGW on Windows",
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "type": "shell",
            "command": "python",
            "args": [
                "${workspaceFolder}\\build.py",
                "--build_variant", "MinGW",
                "--build_type", "${input:buildType}",
                "--build_stage", "Compile"
            ],
            "problemMatcher": []
        },

        {
            "label": "Windows VS2022 MSVC. Compile",
            "detail": "Compile with VS2022 MSVC on Windows",
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "type": "shell",
            "command": "python",
            "args": [
                "${workspaceFolder}\\build.py",
                "--build_variant", "VS2022_MSVC",
                "--build_type", "${input:buildType}",
                "--build_stage", "Compile"
            ],
            "problemMatcher": []
        },

        {
            "label": "Windows Ninja MSVC. Compile",
            "detail": "Compile with Ninja Multi-Config and MSVC on Windows",
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "type": "shell",
            "command": "python",
            "args": [
                "${workspaceFolder}\\build.py",
                "--build_variant", "Ninja_MSVC2022",
                "--build_type", "${input:buildType}",
                "--build_stage", "Compile"
            ],
            "problemMatcher": []
        }
    ]
}
