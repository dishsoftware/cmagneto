{
    "version": "0.2.0",
    "inputs": [
        {
            "id": "iBuildType",
            "type": "pickString",
            "description": "Select build type for launch.json",
            "options": [
                "Debug",
                "RelWithDebInfo"
            ],
            "default": "Debug"
        },
        {
            "id": "iTarget",
            "type": "promptString",
            "description": "Type target for `launch.json`",
            "default": "DishSW_ContactHolder0_GUI"
        }
    ],
    "configurations": [
        {
            "name": "Linux GCC. GDB Launch",
            "type": "cppdbg",
            "request": "launch",
            "cwd":     "${workspaceFolder}/build/Makefiles_GCC/${input:iBuildType}",
            "program": "${workspaceFolder}/build/Makefiles_GCC/${input:iBuildType}/bin/${input:iTarget}",
            "envFile": "${workspaceFolder}/build/Makefiles_GCC/${input:iBuildType}/bin/.env.vscode",
            "stopAtEntry": false,
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ]
        },

        {
            "name": "Windows MinGW. GDB Launch",
            "type": "cppdbg",
            "request": "launch",
            "cwd": "${workspaceFolder}/build/MinGW/${input:iBuildType}",
            "program": "${workspaceFolder}/build/MinGW/${input:iBuildType}/bin/${input:iTarget}",
            "envFile": "${workspaceFolder}/build/MinGW/${input:iBuildType}/bin/.env.vscode",
            "stopAtEntry": false,
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "${env:MSYS2_HOME}/ucrt64/bin/gdb.exe",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ]
        },

        {
            "name": "Windows MSVC. VSDBG Launch",
            "type": "cppvsdbg",
            "request": "launch",
            "cwd":     "${workspaceFolder}/build/VS2022_MSVC/bin/${input:iBuildType}",
            "program": "${workspaceFolder}/build/VS2022_MSVC/bin/${input:iBuildType}/${input:iTarget}",
            "envFile": "${workspaceFolder}/build/VS2022_MSVC/bin/${input:iBuildType}/.env.vscode",
            "stopAtEntry": false,
            "console": "internalConsole"
        },

        {
            "name": "Windows Ninja MSVC. VSDBG Launch",
            "type": "cppvsdbg",
            "request": "launch",
            "cwd":     "${workspaceFolder}/build/Ninja_MSVC2022/bin/${input:iBuildType}",
            "program": "${workspaceFolder}/build/Ninja_MSVC2022/bin/${input:iBuildType}/${input:iTarget}",
            "envFile": "${workspaceFolder}/build/Ninja_MSVC2022/bin/${input:iBuildType}/.env.vscode",
            "stopAtEntry": false,
            "console": "internalConsole"
        }
    ]
}
