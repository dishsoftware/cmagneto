FROM debian:12

# Metadata
## Version of the image, not the project.
LABEL version="1.0.0"

ENV DEBIAN_FRONTEND=noninteractive

# Keep this image intentionally lean so package-manager-installed runtime
# dependencies are exercised by the CI package installation job.
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /project
